{
  "name": "client-merged-bidding-{{job_id}}",
  "intent": "ERC-8183 bidding workflow: approve TTK, create job with BiddingHook, set provider, set budget, fund escrow",
  "original_intent": "{{original_intent}}",
  "execution_plan": "Approve TTK, create open job (provider=0x0, hook=BiddingHook), set provider, set budget, fund escrow",
  "policies": [
    {
      "name": "ttk-approve",
      "type": "contract_call",
      "rules": {
        "effect": "allow",
        "when": {
          "chain_in": ["{{chain}}"],
          "target_in": [{
            "chain_id": "{{chain}}",
            "contract_addr": "{{ttk_addr}}",
            "function_id": "0x095ea7b3"
          }]
        },
        "deny_if": {
          "amount_gt": "{{max_ttk}}"
        },
        "always_review": false
      }
    },
    {
      "name": "erc8183-bidding-ops",
      "type": "contract_call",
      "rules": {
        "effect": "allow",
        "when": {
          "chain_in": ["{{chain}}"],
          "target_in": [{
            "chain_id": "{{chain}}",
            "contract_addr": "{{escrow_addr}}",
            "function_id": "0x41528812"
          }, {
            "chain_id": "{{chain}}",
            "contract_addr": "{{escrow_addr}}",
            "function_id": "0xd0fae591"
          }, {
            "chain_id": "{{chain}}",
            "contract_addr": "{{escrow_addr}}",
            "function_id": "0xc9a84bb9"
          }, {
            "chain_id": "{{chain}}",
            "contract_addr": "{{escrow_addr}}",
            "function_id": "0x9675dc17"
          }, {
            "chain_id": "{{chain}}",
            "contract_addr": "{{escrow_addr}}",
            "function_id": "0xa65e2cfd"
          }, {
            "chain_id": "{{chain}}",
            "contract_addr": "{{bidding_hook_addr}}"
          }]
        },
        "deny_if": {
          "amount_gt": "{{max_eth}}",
          "usage_limits": {
            "rolling_24h": {"tx_count_gt": "{{max_tx}}"}
          }
        },
        "always_review": false
      }
    }
  ],
  "completion_conditions": [
    {"type": "tx_count", "threshold": "5"}
  ]
}
